# ─────────────────────────────────────────────────────────────────────────────
# BrokerAI — PRODUCTION environment template
# Copy this to .env and fill every value before deploying.
# Never commit the filled .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_HEX_CHARS

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Your public domain (used by nginx and OAuth callbacks)
DOMAIN=app.yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=broker
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=brokerai

DATABASE_URL=postgresql+asyncpg://broker:CHANGE_ME_STRONG_PASSWORD@postgres:5432/brokerai
DATABASE_URL_SYNC=postgresql+psycopg2://broker:CHANGE_ME_STRONG_PASSWORD@postgres:5432/brokerai

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=CHANGE_ME_MINIO_USER
S3_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET_NAME=brokerai-documents
S3_REGION=us-east-1

# If using AWS S3 instead of MinIO, remove S3_ENDPOINT_URL and set real credentials.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Token encryption (Fernet) ─────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# ── Email OAuth (optional — only needed if Gmail/Microsoft OAuth is used) ─────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://CHANGE_ME_DOMAIN/api/v1/email/oauth/gmail/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://CHANGE_ME_DOMAIN/api/v1/email/oauth/microsoft/callback

# ── Docker image tag ──────────────────────────────────────────────────────────
IMAGE_TAG=latest
