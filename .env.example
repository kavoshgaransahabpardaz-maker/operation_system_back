# ─────────────────────────────────────────────────────────────────────────────
# BrokerAI — development defaults
# For production, use .env.production as your template instead.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development

SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (matches docker-compose.yml dev service)
POSTGRES_USER=broker
POSTGRES_PASSWORD=broker
POSTGRES_DB=brokerai
DATABASE_URL=postgresql+asyncpg://broker:broker@localhost:5432/brokerai
DATABASE_URL_SYNC=postgresql+psycopg2://broker:broker@localhost:5432/brokerai

# Redis
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/0

# MinIO (local dev)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=brokerai-documents
S3_REGION=us-east-1

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Token encryption — 32-byte Fernet key
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=change-me-to-32-byte-base64-encoded-key

# Email OAuth (optional)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/email/oauth/gmail/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/email/oauth/microsoft/callback

IMAGE_TAG=latest
